{
  "name": "@agntos/agentwallet",
  "version": "1.0.2",
  "description": "Non-custodial, gas-sponsored smart wallets for AI agents on Base. Free gas, spending limits, passkey control.",
  "type": "module",
  "main": "./dist/sdk.js",
  "types": "./dist/sdk.d.ts",
  "bin": {
    "agentwallet": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/sdk.js",
      "types": "./dist/sdk.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "agent",
    "wallet",
    "smart-wallet",
    "base",
    "ethereum",
    "non-custodial",
    "passkey",
    "webauthn",
    "spending-limits",
    "ai-agent",
    "autonomous-agent",
    "crypto",
    "defi"
  ],
  "author": "AgentOS <hello@agntos.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xArtex/agentwallet-aos.git",
    "directory": "cli"
  },
  "homepage": "https://github.com/0xArtex/agentwallet-aos#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7"
  }
}
